# name: ${FILE_PATH}
# description: ${DESCRIPTION}
# group: [sf1]

name Q${QUERY_NUMBER_PADDED}
group tpch
subgroup sf1

require tpch

run
attach './data/generated/duckdb/tpch_sf1.duckdb' as tpch;
use tpch;
pragma tpch(${QUERY_NUMBER})

cleanup
use memory;
detach tpch;

result duckdb/extension/tpch/dbgen/answers/sf1/q${QUERY_NUMBER_PADDED}.csv