# name: test/sql/all_types_multi_threaded.test
# description: Test loading FSST
# group: [sql]

require fastlanes

statement ok
CREATE OR REPLACE MACRO compare_roundtrip(orig_tbl, rt_tbl) AS TABLE
WITH
  orig AS (
    SELECT
      ROW_NUMBER() OVER (ORDER BY id) AS rn,
      id,
      col
    FROM query_table(orig_tbl)
  ),
  rt AS (
    SELECT
      ROW_NUMBER() OVER (ORDER BY id) AS rn,
      id,
      col
    FROM query_table(rt_tbl)
  )
SELECT
  COALESCE(orig.rn, rt.rn)    AS row_pos,
  orig.id                     AS orig_id,
  rt.id                       AS rt_id,
  orig.col                    AS orig_col,
  rt.col                      AS rt_col
FROM orig
FULL OUTER JOIN rt USING (rn)
WHERE
     orig.id        IS DISTINCT FROM rt.id
  OR orig.col       IS DISTINCT FROM rt.col;

statement ok
CREATE TABLE bool_table
AS SELECT
    gs.val AS id,
    (gs.val % 2 = 0) AS col
FROM generate_series(1, 1024) AS gs(val);

statement ok
CREATE TABLE tinyint_table
AS SELECT
    gs.val AS id,
    CAST((gs.val % 256) - 128 AS TINYINT) AS col
FROM generate_series(1, 1024) AS gs(val);

statement ok
CREATE TABLE smallint_table
AS SELECT
    gs.val AS id,
    CAST((gs.val % 65536) - 32768 AS SMALLINT) AS col
FROM generate_series(1, 1024) AS gs(val);

statement ok
CREATE TABLE int_table
AS SELECT
    gs.val AS id,
    CAST(gs.val AS INTEGER) AS col
FROM generate_series(1, 1024) AS gs(val);

statement ok
CREATE TABLE bigint_table
AS SELECT
    gs.val AS id,
    CAST(gs.val * 10 AS BIGINT) AS col
FROM generate_series(1, 1024) AS gs(val);

statement ok
CREATE TABLE ubigint_table
AS SELECT
    gs.val AS id,
    CAST(gs.val as UBIGINT) * 10 AS col
FROM generate_series(1, 1024) AS gs(val);

statement ok
CREATE TABLE hugeint_table
AS SELECT
    gs.val AS id,
    CAST(gs.val as HUGEINT) * -469231731687303715884105728 AS col
FROM generate_series(1, 1024) AS gs(val);

statement ok
CREATE TABLE uhugeint_table
AS SELECT
    gs.val AS id,
    CAST(gs.val as UHUGEINT) * 469231731687303715884105728 AS col
FROM generate_series(1, 1024) AS gs(val);

statement ok
CREATE TABLE float_table
AS SELECT
    gs.val AS id,
    CAST(gs.val AS FLOAT) / 100.0 AS col
FROM generate_series(1, 1024) AS gs(val);

statement ok
CREATE TABLE double_table
AS SELECT
    gs.val AS id,
    CAST(gs.val AS DOUBLE) / 1000.0 AS col
FROM generate_series(1, 1024) AS gs(val);

statement ok
CREATE TABLE decimal_table
AS SELECT
    gs.val AS id,
    CAST(gs.val AS DECIMAL(10, 2)) / 10.0 AS col
FROM generate_series(1, 1024) AS gs(val);

statement ok
CREATE TABLE varchar_table
AS SELECT
    gs.val AS id,
    'Value ' || gs.val AS col
FROM generate_series(1, 1024) AS gs(val);

statement ok
CREATE TABLE date_table
AS SELECT
    gs.val AS id,
    DATE '1992-03-22' + to_days(cast(gs.val AS INTEGER)) AS col
FROM generate_series(1, 1024) AS gs(val);

statement ok
CREATE TABLE timestamp_table
AS SELECT
    gs.val AS id,
    TIMESTAMP '2025-01-01 00:00:00' + to_seconds(CAST(gs.val AS INTEGER)) AS col
FROM generate_series(1, 1024) AS gs(val);

statement ok
CREATE TABLE timestamp_s_table
AS SELECT
    gs.val AS id,
    TIMESTAMP_S '2025-01-01 00:00:00' + to_seconds(CAST(gs.val AS INTEGER)) AS col
FROM generate_series(1, 1024) AS gs(val);

statement ok
CREATE TABLE timestamp_ms_table
AS SELECT
    gs.val AS id,
    TIMESTAMP_MS '2025-01-01 00:00:00' + to_seconds(CAST(gs.val AS INTEGER)) AS col
FROM generate_series(1, 1024) AS gs(val);

statement ok
CREATE TABLE timestamp_ns_table
AS SELECT
    gs.val AS id,
    TIMESTAMP_NS '2025-01-01 00:00:00' + to_seconds(CAST(gs.val AS INTEGER)) AS col
FROM generate_series(1, 1024) AS gs(val);

statement ok
CREATE TABLE blob_table
AS SELECT
    gs.val AS id,
    CAST(md5(CAST(gs.val AS VARCHAR)) AS BLOB) AS col
FROM generate_series(1, 1024) AS gs(val);

statement ok
SET threads=2;

