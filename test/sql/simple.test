# name: test/sql/all_types_multi_threaded.test
# description: Test loading FSST
# group: [sql]

require fastlanes

statement ok
create view lineitem as from read_fls('lineitem.fls');

statement ok
set threads=1;

query IIIII
explain analyze SELECT SUM(
   hash(
     l_orderkey, l_partkey, l_suppkey, l_linenumber,
     l_quantity, l_extendedprice, l_discount, l_tax,
     l_returnflag, l_linestatus,
     l_shipdate, l_commitdate, l_receiptdate,
     l_shipinstruct, l_shipmode, l_comment
   )) AS row_hash_sum FROM lineitem;
